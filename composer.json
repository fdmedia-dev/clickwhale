{
    "name": "clickwhale/clickwhale",
    "description": "Link Organizer and Click Tracking Solution",
    "type": "project",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Clickwhale\\": "src/"
        }
    },
    "authors": [
        {
            "name": "peterkrupenya",
            "email": "62963646+peterkrupenya@users.noreply.github.com"
        }
    ],
    "minimum-stability": "dev",
    "require": {
        "whichbrowser/parser": "dev-master"
    },
    "require-dev": {
        "brianhenryie/strauss": "dev-master"
    },
    "scripts": {
        "strauss": [
            "vendor/bin/strauss"
        ],
        "post-install-cmd": [
            "@strauss"
        ],
        "post-update-cmd": [
            "@strauss"
        ]
    },
    "extra": {
        "strauss": {
            "target_directory": "inc",
            "namespace_prefix": "Clickwhale\\Vendor\\",
            "classmap_prefix": "Clickwhale_Vendor_",
            "constant_prefix": "CLICKWHALE_VENDOR_",
            "packages": [
            ],
            "override_autoload": {
            },
            "exclude_from_copy": {
                "packages": [
                ],
                "namespaces": [
                ],
                "file_patterns": [
                ]
            },
            "exclude_from_prefix": {
                "packages": [
                ],
                "namespaces": [
                ],
                "file_patterns": [
                    "/^psr.*$/"
                ]
            },
            "namespace_replacement_patterns" : {
            },
            "delete_vendor_files": false
        }
    }
}